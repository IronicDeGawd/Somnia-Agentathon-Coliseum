{
  "name": "coliseum",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "node": "hardhat node",
    "deploy:ping": "hardhat run scripts/deploy-ping.ts --network somnia",
    "deploy:ping:local": "hardhat run scripts/deploy-ping.ts --network localhost",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network somnia",
    "smoke:local": "hardhat run scripts/smoke.ts --network localhost",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:start:prod": "NODE_ENV=production pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:reload": "pm2 reload ecosystem.config.js",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs",
    "watcher": "hardhat run scripts/watcher-bot.ts --network somnia",
    "seeder": "hardhat run scripts/seeder-bot.ts --network somnia"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "5.0.0",
    "@nomicfoundation/hardhat-viem": "2.0.6",
    "@types/node": "^22.0.0",
    "dotenv": "16.5.0",
    "hardhat": "^2.28.0",
    "ts-node": "10.9.2",
    "typescript": "5.8.3"
  },
  "dependencies": {
    "@somnia-chain/reactivity": "^0.1.10",
    "@somnia-chain/reactivity-contracts": "^0.2.0",
    "viem": "~2.37.8"
  }
}
