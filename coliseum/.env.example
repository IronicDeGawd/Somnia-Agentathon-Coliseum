# Copy to .env and fill in
PRIVATE_KEY=0x...your_testnet_private_key

# Somnia testnet
RPC_HTTP=https://api.infra.testnet.somnia.network
RPC_WS=wss://api.infra.testnet.somnia.network

# dreamDEX testnet (confirmed host)
DREAMDEX_HTTP=https://stg.api.dreamdex.io
DREAMDEX_WS=wss://stg.api.dreamdex.io/v0/ws/public

# Filled after deploy-ping.ts runs
PING_ADDRESS=

# Seeder / MM bot wallet — sweepStt() target and top-up destination for the
# watcher-bot. Generate a fresh EVM key (any tool: viem generatePrivateKey,
# `cast wallet new`, etc.) and paste the resulting address + private key.
SEEDER_ADDRESS=0x...
SEEDER_PRIVATE_KEY=0x...

# --- watcher-bot tuning (all STT, whole tokens) ---
# WATCHER_INTERVAL_S=60        # loop seconds (0 = one-shot)
# SWEEP_THRESHOLD_STT=5        # sweep SwapFallback STT → seeder when ≥ this
# SEEDER_MIN_STT=50            # refill seeder when its STT drops below this
# SEEDER_TOPUP_STT=100         # STT to send per top-up
# ARENA_MIN_STT=5              # refill Arena LLM fuel when its STT drops below this
# ARENA_TOPUP_STT=10           # STT to send the Arena per top-up
# DEPLOYER_MIN_STT=20          # never drain the deployer below this

# --- seeder-bot tuning (MM resting bid on SOMI/USDso) ---
# SEEDER_USDSO_BUDGET=3        # one-time USDso committed to bids, then idle
# SEEDER_SPREAD_TICKS=2        # rest the bid this many ticks below best ask
# SEEDER_REPRICE_TICKS=5       # only cancel+repost if the bid drifts > this
# SEEDER_INTERVAL_S=45         # loop seconds (0 = one-shot)
# DEPLOYER_USDSO_MIN=0.5       # never pull deployer USDso below this on bootstrap
